# Database (Neon PostgreSQL — use ap-south-1 Mumbai region for DPDP compliance)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth (generate secret with: openssl rand -base64 32)
NEXTAUTH_SECRET="generate-a-strong-random-secret-here"
NEXTAUTH_URL="https://www.oniq7.com"

# Encryption key for sensitive fields (generate with: openssl rand -base64 32)
ENCRYPTION_KEY="generate-a-strong-encryption-key-here"

# Razorpay (optional — not needed during beta)
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""

# Anthropic AI (optional — for AI chatbot)
# ANTHROPIC_API_KEY=""
